{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile settings and demographic options",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "ageConfirmed": { "type": "boolean" },
        "aiPersonalizationEnabled": { "type": "boolean" },
        "analyticsEnabled": { "type": "boolean" }
      },
      "required": ["uid", "displayName", "createdAt", "ageConfirmed"]
    },
    "Habit": {
      "title": "Habit",
      "description": "A habit or addiction the user is trying to reduce or overcome",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["Alcohol", "Smoking/Vaping", "Substances", "Gambling", "Digital/Screen Time", "Other"] },
        "goal": { "type": "string" },
        "triggers": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "streak": { "type": "integer" },
        "lastCleanDate": { "type": "string" }
      },
      "required": ["id", "userId", "name", "category", "createdAt", "streak"]
    },
    "Entry": {
      "title": "Entry",
      "description": "An urge, progress log, or relapse event",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "habitId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["urge", "relapse", "clean_day"] },
        "intensity": { "type": "integer", "description": "1 to 10 rating for urges" },
        "notes": { "type": "string" },
        "trigger": { "type": "string" },
        "mood": { "type": "string" }
      },
      "required": ["id", "userId", "habitId", "timestamp", "type"]
    },
    "Journal": {
      "title": "Journal",
      "description": "Personal secure journal entries and reflections",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "mood": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "content", "createdAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Coaching conversation messages",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "sender": { "type": "string", "enum": ["user", "ai"] },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "sender", "message", "timestamp"]
    },
    "Consent": {
      "title": "Consent",
      "description": "Consent history record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "consentCategory": { "type": "string" },
        "status": { "type": "boolean" },
        "noticeVersion": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "consentCategory", "status", "noticeVersion", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "Private profile of the authenticated user"
    },
    "users/{userId}/habits/{habitId}": {
      "schema": "Habit",
      "description": "The user's list of habits being recovered from"
    },
    "users/{userId}/entries/{entryId}": {
      "schema": "Entry",
      "description": "Activity logs, urges, or relapse incidents"
    },
    "users/{userId}/journal/{journalId}": {
      "schema": "Journal",
      "description": "Personal journal entries"
    },
    "users/{userId}/chat/{messageId}": {
      "schema": "ChatMessage",
      "description": "Coaching chat history"
    },
    "users/{userId}/consents/{consentId}": {
      "schema": "Consent",
      "description": "Record of user's active/historic consents"
    }
  }
}
